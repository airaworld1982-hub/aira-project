# ═══════════════════════════════════════════════
# AIRA Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── MongoDB ─────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/aira_db?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# ── Admin Credentials ───────────────────────────
# First admin user created on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_EMAIL=admin@airaworld.org

# ── Pusher (WebRTC Signaling) ───────────────────
# Get from: https://pusher.com → App Keys
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# ── Frontend URL (CORS) ─────────────────────────
# Your live domain, comma-separated for multiple
FRONTEND_URL=https://airaworld.org

# ── Rate Limiting ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
